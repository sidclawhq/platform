# ============================================================
# SidClaw — Environment Configuration
# Copy to .env and fill in values
# ============================================================

# --- Database ---
DB_NAME=sidclaw
DB_USER=sidclaw
DB_PASSWORD=                            # REQUIRED — strong password

# --- API Server ---
NODE_ENV=production
SESSION_SECRET=                         # REQUIRED — min 32 chars, generate with: openssl rand -hex 32
ALLOWED_ORIGINS=https://app.sidclaw.com # comma-separated list

# --- Authentication (at least one provider required) ---
# OIDC (Okta / Auth0)
OIDC_ISSUER=                            # e.g., https://your-org.okta.com/oauth2/default
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=https://api.sidclaw.com/api/v1/auth/callback

# GitHub OAuth (for self-serve signup)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://api.sidclaw.com/api/v1/auth/callback/github

# Google OIDC (for self-serve signup)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://api.sidclaw.com/api/v1/auth/callback/google

# --- Email Notifications (optional) ---
EMAIL_API_KEY=                          # Resend API key (re_...)
EMAIL_FROM=SidClaw <notifications@sidclaw.com>

# --- URLs ---
API_URL=https://api.sidclaw.com
DASHBOARD_URL=https://app.sidclaw.com

# --- Rate Limiting ---
RATE_LIMIT_ENABLED=true

# --- Ports (for docker-compose) ---
API_PORT=4000
DASHBOARD_PORT=3000
DOCS_PORT=3001
LANDING_PORT=3002

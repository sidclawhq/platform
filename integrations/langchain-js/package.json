    "@langchain/core": ">=0.2.0"
  },
  "dependencies": {
    "@sidclaw/sdk": ">=0.1.0"
  },
  "devDependencies": {
    "@langchain/core": "^0.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run"
  }

{
  "name": "@sidclaw/langchain-governance",
  "version": "0.1.0",
  "description": "SidClaw governance integration for LangChain.js — policy evaluation, human approval, and audit trails",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",

DATABASE_URL=postgresql://agent_identity:agent_identity@localhost:5432/agent_identity
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# Email notifications (optional — logs to console if not set)
EMAIL_API_KEY=re_...
EMAIL_FROM=SidClaw <notifications@sidclaw.com>
DASHBOARD_URL=http://localhost:3000

# Rate limiting (set to false for development)
RATE_LIMIT_ENABLED=true

# GitHub OAuth (optional — signup via GitHub disabled if not set)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:4000/api/v1/auth/callback/github

# Google OIDC (optional — signup via Google disabled if not set)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/callback/google

# Stripe Billing (optional — billing features disabled if not set)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_STARTER_PRICE_ID=price_...    # Starter plan CHF 199/mo
STRIPE_BUSINESS_PRICE_ID=price_...   # Business plan CHF 999/mo
STRIPE_WEBHOOK_SECRET=whsec_...

# Platform Admin
SUPER_ADMIN_KEY=               # generate with: openssl rand -hex 32

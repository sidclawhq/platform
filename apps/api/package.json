{
  "name": "@sidclaw/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc --build",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'no linter configured yet'",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@fastify/cors": "^11",
    "@fastify/helmet": "^13.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@sidclaw/shared": "*",
    "bcrypt": "^6.0.0",
    "cookie": "^1.1.1",
    "fastify": "^5",
    "fastify-plugin": "^5.1.0",
    "openid-client": "^6.8.2",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "resend": "^6.9.4",
    "stripe": "^20.4.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cookie": "^0.6.0",
    "@types/node": "^20.19.37",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.2",
    "dotenv": "^16.6.1",
    "prisma": "^7.6.0",
    "tsx": "^4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

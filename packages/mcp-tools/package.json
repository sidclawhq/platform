{
  "name": "@sidclaw/mcp-tools",
  "version": "0.1.1",
  "description": "MCP server that exposes SidClaw governance as tools — any MCP-compatible agent gets policy checks, approvals, and audit traces.",
  "license": "MIT",
  "author": "SidClaw",
  "type": "module",
  "bin": {
    "sidclaw-mcp-tools": "./bin/sidclaw-mcp-tools.cjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sidclaw",
    "ai-agent-governance",
    "approval-workflow",
    "audit-trail"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sidclawhq/platform",
    "directory": "packages/mcp-tools"
  },
  "homepage": "https://sidclaw.com",
  "bugs": {
    "url": "https://github.com/sidclawhq/platform/issues"
  }
}
